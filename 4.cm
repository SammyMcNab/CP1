/* A program to compute the factorial value of an integer */
/* Program starts with error "vod" but recovers when it reaches the next valid function */


vod main(void) {
  int x; 
  int fac;

  x = input();
  fac = 1;
  while (x > 1) {
    fac = fac * x;
    x = x - 1;
  } 

  output(fac);
}

void main(void) {
  int x; 
  int fac;

  x = input();
  fac = 1;

  output(fac);
}